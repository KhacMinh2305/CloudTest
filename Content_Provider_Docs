2.2 Trong app truy xuất dữ liệu:
2.2.1 MediaItemLoader:

object MediaItemLoader {

    const val PROVIDER_URI = "content://com.minhdk.provider.media.provider/media"

    fun loadMedia(context: Context): List<MediaItem> {
        val list = mutableListOf<MediaItem>()

        val cursor = context.contentResolver.query(
            PROVIDER_URI.toUri(),
            null,
            null,
            null,
            null
        )

        Log.d("minhdk", "Cursor from provider: $cursor")

        cursor?.use {
            while (it.moveToNext()) {
                list.add(
                    MediaItem(
                        id = it.getLong(it.getColumnIndexOrThrow("_id")),
                        childId = it.getLong(it.getColumnIndexOrThrow("childId")),
                        title = it.getString(it.getColumnIndexOrThrow("title")),
                        imageUrl = it.getString(it.getColumnIndexOrThrow("imageUrl")),
                        contentUrl = it.getString(it.getColumnIndexOrThrow("contentUrl")),
                        type = it.getString(it.getColumnIndexOrThrow("type"))
                    )
                )
            }
        }

        return list
    }
}

